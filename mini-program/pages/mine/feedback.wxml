<view class="container" style="{{pageStyle}}">
  <view class="form-card">
    <view class="form-header-row">
      <view class="form-title">意见反馈</view>
      <view
        class="record-chip"
        hover-class="record-chip-hover"
        hover-stay-time="80"
        bindtap="goFeedbackRecords"
      >
        <text class="record-chip-text">反馈记录</text>
        <text class="record-chip-arrow">›</text>
      </view>
    </view>
    <view class="form-subtitle">遇到问题或有好的建议？告诉我们吧～</view>

    <view class="field">
      <view class="field-label">反馈内容 <text class="required">*</text></view>
      <textarea
        class="textarea"
        placeholder="请详细描述您遇到的问题或建议..."
        bindinput="onContentInput"
        value="{{content}}"
        maxlength="500"
        auto-height
      />
      <view class="word-count">{{content.length || 0}}/500</view>
    </view>

    <view class="field">
      <view class="field-label">联系方式</view>
      <input
        class="input"
        placeholder="手机号 / 邮箱（选填）"
        bindinput="onContactInput"
        value="{{contact}}"
      />
    </view>

    <button
      class="submit-btn"
      hover-class="submit-btn-hover"
      bindtap="submit"
      disabled="{{!content || submitting}}"
    >
      <text wx:if="{{submitting}}">提交中…</text>
      <text wx:else>提交反馈</text>
    </button>
  </view>
</view>
