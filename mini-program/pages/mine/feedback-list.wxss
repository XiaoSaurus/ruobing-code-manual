.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, var(--theme-light, #f5f7fa) 0%, #f0f2f5 240rpx);
}

.page-head {
  margin-bottom: 28rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1c1c28;
}

.page-sub {
  font-size: 24rpx;
  color: #909399;
  margin-top: 8rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.fb-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.fb-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.fb-time {
  font-size: 24rpx;
  color: #909399;
}

.fb-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.fb-status.pending {
  background: rgba(230, 162, 60, 0.12);
  color: #e6a23c;
}

.fb-status.done {
  background: rgba(103, 194, 58, 0.12);
  color: #67c23a;
}

.fb-content {
  font-size: 28rpx;
  color: #303133;
  line-height: 1.65;
  word-break: break-all;
}

.fb-contact {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #909399;
}

.fb-reply-wrap {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #ebeef5;
}

.fb-reply-label {
  font-size: 24rpx;
  color: var(--theme-dark, #409eff);
  font-weight: 600;
  margin-bottom: 10rpx;
}

.fb-reply {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.6;
  word-break: break-all;
}

.empty {
  text-align: center;
  padding: 120rpx 40rpx;
  font-size: 28rpx;
  color: #c0c4cc;
}
