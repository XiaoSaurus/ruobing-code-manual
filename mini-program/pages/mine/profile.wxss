/* 个人资料页：随全局主题 --theme-color / --theme-light / --theme-dark */
.profile-page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--theme-light, #f5f7fa) 0%, #f0f2f5 240rpx);
  padding: 24rpx 20rpx 60rpx;
  box-sizing: border-box;
}

/* 头部信息卡 */
.profile-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
  overflow: visible;
}

/* 微信头像按钮：与下方表单区同一套灰阶与字重；plain 去默认绿底 */
.avatar-choose-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 16rpx 24rpx 20rpx;
  margin: 0;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: transparent !important;
  border: none !important;
  line-height: normal;
  font-size: inherit;
}

.avatar-choose-btn::after {
  border: none !important;
}

/* 点击态：与表单行轻触反馈接近的浅灰底 */
.avatar-choose-hover {
  opacity: 1;
  background: rgba(0, 0, 0, 0.04) !important;
}

.avatar-ring {
  padding: 6rpx;
  border-radius: 50%;
  background: linear-gradient(
    160deg,
    var(--theme-light, #eceef2) 0%,
    rgba(255, 255, 255, 0.95) 100%
  );
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.avatar-img {
  display: block;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-sizing: border-box;
}

/* 与 .item-value 一致：28rpx / #666，去掉高饱和蓝底，避免和表单区割裂 */
.avatar-hint {
  margin-top: 22rpx;
  font-size: 28rpx;
  color: var(--theme-dark, #409eff);
  opacity: 0.75;
  line-height: 1.45;
  padding: 0;
  font-weight: 400;
  background: transparent;
}

.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-top: 28rpx;
  text-align: center;
  max-width: 100%;
}

/* 编辑表单 */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  margin-bottom: 40rpx;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f5;
  min-height: 96rpx;
  box-sizing: border-box;
}

.form-item-last {
  border-bottom: none;
}

.item-label {
  flex-shrink: 0;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.item-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
  margin-left: 24rpx;
}

.item-value {
  font-size: 28rpx;
  color: #666;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 420rpx;
}

.item-value.placeholder {
  color: #bbb;
}

.arrow {
  flex-shrink: 0;
  color: var(--theme-color, #66b1ff);
  opacity: 0.45;
  font-size: 36rpx;
  font-weight: 300;
  margin-left: 12rpx;
  line-height: 1;
}

/* 保存按钮 */
.save-btn {
  background: linear-gradient(135deg, var(--theme-dark, #409eff) 0%, var(--theme-color, #66b1ff) 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 0;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.12);
  width: 100%;
  line-height: 2.8;
  letter-spacing: 2rpx;
}

.save-btn::after {
  border: none;
}
