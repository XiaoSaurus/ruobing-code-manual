/* 个人资料页 */
.profile-page {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 24rpx 20rpx 60rpx;
}

/* 头部信息卡 */
.profile-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 48rpx 0 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}
.avatar-wrap {
  position: relative;
}
.avatar-img {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 6rpx solid #f0f0f5;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}
.avatar-tip {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.45);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}
.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-top: 20rpx;
}

/* 编辑表单 */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
  margin-bottom: 40rpx;
}
.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f5;
}
.item-label {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
}
.item-right {
  display: flex;
  align-items: center;
}
.item-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}
.item-value {
  font-size: 28rpx;
  color: #888;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-value.placeholder {
  color: #ccc;
}
.arrow {
  color: #d0d0d8;
  font-size: 36rpx;
  font-weight: 300;
  margin-left: 12rpx;
}

/* 保存按钮 */
.save-btn {
  background: linear-gradient(135deg, #5b9cf6, #7c6cf6);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 0;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(91,156,246,0.35);
  width: 100%;
  line-height: 2.8;
  letter-spacing: 2rpx;
}
.save-btn::after { border: none; }

/* 退出登录 */
.logout-row {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.logout-text {
  font-size: 30rpx;
  color: #ff4757;
}

/* 头像按钮：去除默认边框和背景 */
.avatar-head-btn,
.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}
.avatar-head-btn::after,
.avatar-btn::after {
  border: none;
}
/* 表格内头像按钮需要撑满一行 */
.avatar-btn {
  display: block;
  width: 100%;
}
.avatar-form-item {
  border-bottom: 1rpx solid #f0f0f5;
}
