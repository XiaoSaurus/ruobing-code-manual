.container { padding: 30rpx; min-height: 100vh; background: #f5f5f5; }
.tip { font-size: 26rpx; color: #999; margin-bottom: 30rpx; padding-left: 10rpx; }

.theme-list {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.theme-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  position: relative;
}
.theme-item.active::after {
  content: '';
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 12rpx;
  height: 12rpx;
  background: #67c23a;
  border-radius: 50%;
}
.color-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
  transition: transform 0.2s;
}
.theme-item.active .color-circle { transform: scale(1.15); }
.check { font-size: 32rpx; font-weight: bold; }
.theme-name { font-size: 26rpx; color: #333; margin-bottom: 6rpx; font-weight: 500; }
.theme-hex { font-size: 20rpx; color: #bbb; }

.preview { background: #fff; border-radius: 16rpx; padding: 30rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.preview-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }

/* 与「我的」页用户卡一致（头像区预览） */
.preview .user-card {
  border-radius: 20rpx;
  margin-bottom: 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.preview .user-card.logged {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 30rpx;
}
.preview .user-card.logged .user-info {
  flex: 1;
  display: flex;
  align-items: center;
}
.preview .logout-area { flex-shrink: 0; }
.preview .user-info {
  display: flex;
  align-items: center;
  position: relative;
}
.preview .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.6);
  flex-shrink: 0;
}
.preview .user-text { margin-left: 28rpx; flex: 1; }
.preview .nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
}
.preview .tip {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
}
.preview .logout-btn {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
}
.preview .user-card--light .nickname { color: #333; }
.preview .user-card--light .tip { color: #666; }
.preview .user-card--light .avatar { border-color: rgba(0,0,0,0.08); }
.preview .user-card--light .logout-btn {
  color: var(--theme-color);
  background: rgba(255,255,255,0.95);
  border: 1rpx solid var(--theme-color);
}
