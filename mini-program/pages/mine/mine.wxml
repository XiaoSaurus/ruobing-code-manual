<view class="container" style="{{pageStyle}}">
  <!-- 用户信息卡：未登录 -->
  <view class="user-card {{userCardLight ? 'user-card--light' : ''}}" style="background: {{userCardBg}};" wx:if="{{!userInfo}}" bindtap="goLogin">
    <view class="user-info">
      <image class="avatar" src="/static/default-avatar.png" mode="aspectFill" />
      <view class="user-text">
        <text class="nickname">点击登录</text>
        <text class="tip">登录后解锁更多功能</text>
      </view>
      <view class="login-icon">
        <text class="arrow-text">›</text>
      </view>
    </view>
  </view>

  <!-- 用户信息卡：已登录 -->
  <view class="user-card logged {{userCardLight ? 'user-card--light' : ''}}" style="background: {{userCardBg}};" wx:if="{{userInfo}}">
    <view class="user-info" bindtap="goProfile">
      <image class="avatar" src="{{userInfo.avatarUrl || '/static/default-avatar.png'}}" mode="aspectFill" />
      <view class="user-text">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="tip">点击编辑个人资料</text>
      </view>
    </view>
    <view class="logout-area" catchtap="logout">
      <text class="logout-btn">退出</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <!-- 登录后才显示：个人资料 -->
    <view class="menu-item" bindtap="goProfile" wx:if="{{userInfo}}">
      <view class="menu-left">
        <image class="menu-icon" src="/static/icons/icon-profile.png" mode="aspectFit" />
        <text class="menu-label">个人资料</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goFeedback">
      <view class="menu-left">
        <image class="menu-icon" src="/static/icons/icon-feedback.png" mode="aspectFit" />
        <text class="menu-label">意见反馈</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goChangelog">
      <view class="menu-left">
        <image class="menu-icon" src="/static/icons/icon-changelog.png" mode="aspectFit" />
        <text class="menu-label">更新日志</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <view class="menu-left">
        <image class="menu-icon" src="/static/icons/icon-about.png" mode="aspectFit" />
        <text class="menu-label">关于我们</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goTheme" style="border-bottom: none;">
      <view class="menu-left">
        <image class="menu-icon" src="/static/icons/icon-theme.png" mode="aspectFit" />
        <text class="menu-label">切换主题</text>
      </view>
      <view class="right-content">
        <view class="theme-dot" style="background: {{themeColor}};"></view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 分享 -->
  <button class="share-btn" open-type="share">
    <text>分享给好友</text>
  </button>
</view>
