<view class="profile-page" style="{{pageStyle}}">
  <!-- 头部：头像 + 提示文案（纵向排版，避免与昵称重叠、遮挡） -->
  <view class="profile-card">
    <!-- 官方「使用微信头像」：open-type="chooseAvatar"，需基础库 ≥2.21.2 -->
    <button
      class="avatar-choose-btn"
      plain
      hover-class="avatar-choose-hover"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
    >
      <view class="avatar-ring">
        <image class="avatar-img" src="{{form.avatarUrl || '/static/default-avatar.png'}}" mode="aspectFill" />
      </view>
      <text class="avatar-hint">使用微信头像</text>
    </button>
    <text class="profile-name">{{form.nickName || '未设置昵称'}}</text>
  </view>

  <!-- 编辑表单 -->
  <view class="form-card">
    <view class="form-item" bindtap="editNickname">
      <text class="item-label">昵称</text>
      <view class="item-right">
        <text class="item-value {{form.nickName ? '' : 'placeholder'}}">{{form.nickName || '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="form-item" bindtap="editGender">
      <text class="item-label">性别</text>
      <view class="item-right">
        <text class="item-value">{{genderText}}</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <picker mode="region" value="{{regionValue}}" bindchange="onRegionChange">
      <view class="form-item form-item-last">
        <text class="item-label">地区</text>
        <view class="item-right">
          <text class="item-value {{regionDisplayText ? '' : 'placeholder'}}">{{regionDisplayText || '请选择省市区'}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </picker>
  </view>

  <button class="save-btn" bindtap="saveProfile">保存修改</button>
</view>
