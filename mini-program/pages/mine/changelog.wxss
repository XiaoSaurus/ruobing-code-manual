.container { padding: 30rpx; min-height: 100vh; background: #f5f5f5; }

.header {
  margin-bottom: 30rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}
.header-subtitle {
  font-size: 26rpx;
  color: #999;
}

.timeline { position: relative; }

.timeline-item {
  display: flex;
  margin-bottom: 30rpx;
  position: relative;
}

.timeline-left {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #409eff;
  flex-shrink: 0;
  margin-top: 6rpx;
  box-shadow: 0 0 0 6rpx rgba(64,158,255,0.15);
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: #e4e7ed;
  margin-top: 8rpx;
}

.timeline-right { flex: 1; }

.version-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.version-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.version-tag {
  font-size: 28rpx;
  font-weight: 600;
  color: #409eff;
  background: #ecf5ff;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

.version-date {
  font-size: 22rpx;
  color: #bbb;
}

.version-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.version-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  font-size: 28rpx;
  color: #bbb;
}
