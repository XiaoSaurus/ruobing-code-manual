.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--theme-light, #f0f4f8) 0%, #f5f5f5 200rpx);
  box-sizing: border-box;
}

.header {
  margin-bottom: 30rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}
.header-subtitle {
  font-size: 26rpx;
  color: #999;
}

.timeline { position: relative; }

.timeline-item {
  display: flex;
  margin-bottom: 30rpx;
  position: relative;
}

.timeline-left {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--theme-color, #409eff);
  flex-shrink: 0;
  margin-top: 6rpx;
  box-shadow: 0 0 0 6rpx var(--theme-light, rgba(64, 158, 255, 0.15));
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: #e4e7ed;
  margin-top: 8rpx;
}

.timeline-right { flex: 1; }

.version-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.version-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.version-tag {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--theme-color, #409eff);
  background: var(--theme-light, #ecf5ff);
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

.version-date {
  font-size: 22rpx;
  color: #bbb;
}

/* 标题 + 右侧箭头，整行可点 */
.version-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 12rpx 0 4rpx;
}

.version-title-text {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.45;
  padding-right: 16rpx;
}

.title-arrow {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--theme-color, #909399);
  line-height: 1;
  padding: 8rpx 4rpx 8rpx 12rpx;
}

/* 详情子卡片：背景固定中性灰，不随主题浅色变化；左侧仍可保留主题色条 */
.detail-subcard {
  margin-top: 20rpx;
  padding: 24rpx 22rpx 24rpx 26rpx;
  background: #f5f7fa;
  border-radius: 14rpx;
  border: 1rpx solid #e4e7ed;
  border-left: 6rpx solid var(--theme-color, #409eff);
  box-sizing: border-box;
}

.version-content-md {
  display: block;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  font-size: 28rpx;
  color: #bbb;
}
