/* 我的页面 */
.container { padding: 20rpx; min-height: 100vh; background: #f5f5f5; }

/* 用户卡 */
.user-card {
  border-radius: 20rpx;
  padding: 50rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}
.user-info {
  display: flex;
  align-items: center;
  position: relative;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.6);
  flex-shrink: 0;
}
.user-text {
  margin-left: 28rpx;
  flex: 1;
}
.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
}
.tip {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
}
.login-icon {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #fff;
  font-size: 40rpx;
}
.logout-btn {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

/* 菜单卡 */
.menu-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.menu-left {
  display: flex;
  align-items: center;
}
.iconfont {
  font-size: 36rpx;
  margin-right: 20rpx;
}
.menu-label {
  font-size: 30rpx;
  color: #333;
}
.arrow {
  color: #ccc;
  font-size: 40rpx;
  font-weight: 300;
}
.right-content {
  display: flex;
  align-items: center;
}
.theme-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

/* 分享按钮 */
.share-btn {
  width: 100%;
  background: #fff;
  border-radius: 50rpx;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  padding: 0;
  line-height: 2.8;
}
.share-btn::after { border: none; }

/* 版本 */
.version-info {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 20rpx;
}
