<view class="container" style="{{pageStyle}}">
  <view class="tip">选择你喜欢的主题颜色</view>

  <view class="theme-list">
    <view
      class="theme-item {{currentTheme.id === item.id ? 'active' : ''}}"
      wx:for="{{themes}}"
      wx:key="id"
      bindtap="selectTheme"
      data-theme="{{item}}"
    >
      <view class="color-circle" style="background: linear-gradient(160deg, {{item.light}} 0%, {{item.color}} 100%);">
        <text wx:if="{{currentTheme.id === item.id}}" class="check" style="color: {{item.dark}};">✓</text>
      </view>
      <text class="theme-name">{{item.name}}</text>
      <text class="theme-hex">{{item.color}}</text>
    </view>
  </view>

  <view class="preview">
    <view class="preview-title">效果预览</view>
    <view
      class="user-card logged {{previewUserCardLight ? 'user-card--light' : ''}}"
      style="background: {{previewUserCardBg}};"
    >
      <view class="user-info">
        <image class="avatar" src="/static/default-avatar.png" mode="aspectFill" />
        <view class="user-text">
          <text class="nickname">主题预览</text>
          <text class="tip">个人中心头像区域效果</text>
        </view>
      </view>
      <view class="logout-area">
        <text class="logout-btn">退出</text>
      </view>
    </view>
  </view>
</view>
