/* 关于我们：每块独立卡片 */

.container {
  min-height: 100vh;
  padding: 20rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, var(--theme-light, #eceef2) 0%, #eceef2 220rpx);
}

.about-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* 顶部品牌区 */
.about-hero {
  padding: 40rpx 36rpx 36rpx;
  text-align: center;
  background: linear-gradient(
    180deg,
    var(--theme-light, #e8f4ff) 0%,
    #ffffff 100%
  );
}

.logo-badge {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 20rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon-img {
  width: 80rpx;
  height: 80rpx;
}

.app-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #1c1c28;
  letter-spacing: 1rpx;
}

.app-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9090a0;
  letter-spacing: 4rpx;
}

.about-body > view {
  margin-bottom: 20rpx;
}

.about-body > view:last-child {
  margin-bottom: 0;
}

/* 内容分块：独立卡片 */
.md-block {
  padding: 28rpx 28rpx 30rpx;
  margin: 0;
}

.md-block--lead {
  padding-top: 26rpx;
}

/* 各块标题：与「提供什么」一致，仅标题；正文在内层卡片 */
.md-h2 {
  font-size: 34rpx;
  font-weight: 700;
  color: #1c1c28;
  line-height: 1.35;
  margin-bottom: 0;
}

.md-p {
  display: block;
  font-size: 28rpx;
  color: #4a4a58;
  line-height: 1.82;
  text-align: justify;
}

/* 纯文案内层卡片：避免标签内缩进空白 + 两端对齐导致首行异常，用左对齐 */
.feature-sheet--plain .md-p {
  text-align: left;
}

.md-p--small {
  font-size: 26rpx;
  line-height: 1.78;
}

.feature-sheet--muted .md-p--small {
  color: #5e5e6e;
}

/* 提供什么 / 简介 / 定位 / 使用与版权：内层内容区 */
.feature-sheet {
  margin-top: 12rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f4f6f9;
  border: 1rpx solid #e8eaef;
}

/* 纯文案卡片（无列表行） */
.feature-sheet--plain {
  padding: 26rpx 24rpx 28rpx;
}

.feature-sheet--plain .sheet-text {
  display: block;
}

/* 版权段略深底，与正文区分 */
.feature-sheet--muted {
  background: #eef1f6;
  border-color: #dfe3e9;
}

.feature-list {
  display: flex;
  flex-direction: column;
}

.feature-chip {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 20rpx;
  border-radius: 0;
  margin: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  border-bottom: 1rpx solid #e8eaef;
}

.feature-chip:last-child {
  border-bottom: none;
}

.feature-dot {
  width: 8rpx;
  min-height: 28rpx;
  border-radius: 4rpx;
  margin-top: 8rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, var(--theme-color, #66b1ff), var(--theme-dark, #409eff));
  opacity: 0.9;
}

.feature-text-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1c28;
}

.feature-desc {
  margin-top: 6rpx;
  font-size: 25rpx;
  color: #7a7a8a;
  line-height: 1.62;
}

/* 版本卡片 */
.version-pill {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0;
  padding: 26rpx 28rpx;
}

.version-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1c28;
}

.version-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--theme-dark, #409eff);
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: var(--theme-light, rgba(64, 158, 255, 0.12));
}

