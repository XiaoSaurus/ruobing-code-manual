.container { padding: 30rpx; min-height: 100vh; background: #f5f5f5; }

.about-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.about-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.logo-icon-img {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #333;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 30rpx 0;
}

.about-body {
  font-size: 28rpx;
  color: #555;
  line-height: 1.9;
}

.about-desc {
  display: block;
  margin-bottom: 30rpx;
}

.feature-list { margin-top: 20rpx; }

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #555;
}

.feature-icon-img {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.contact-section { }

.contact-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}
