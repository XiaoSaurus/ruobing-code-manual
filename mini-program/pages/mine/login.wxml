<view class="login-page">
  <!-- 顶部装饰 -->
  <view class="top-decoration"></view>

  <!-- Logo 区域 -->
  <view class="logo-area">
    <view class="logo-wrap">
      <view class="logo-icon">📖</view>
    </view>
    <text class="app-name">若冰代码手册</text>
    <text class="app-slogan">专业的代码分享平台</text>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <text class="card-title">欢迎回来</text>
    <text class="card-desc">登录后解锁更多精彩内容</text>

    <!-- 微信授权登录按钮 -->
    <button class="wx-login-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      <view class="btn-inner">
        <text class="btn-icon">微</text>
        <text class="btn-text">微信授权登录</text>
      </view>
    </button>

    <!-- 备选：用户信息登录 -->
    <view class="alt-login" bindtap="onGuestLogin">
      <text class="alt-text">暂不登录，先看看</text>
    </view>
  </view>

  <!-- 用户协议 -->
  <view class="agreement">
    <text>登录即表示同意</text>
    <text class="link">《用户协议》</text>
    <text>和</text>
    <text class="link">《隐私政策》</text>
  </view>
</view>
