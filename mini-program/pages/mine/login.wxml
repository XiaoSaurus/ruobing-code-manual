<!--
  Logo：mini-program/static/ruobing-it_favicon.png
-->
<view class="login-page" style="{{pageStyle}}">
  <view class="top-decoration"></view>

  <view class="logo-area">
    <view class="logo-wrap">
      <image class="logo-img" src="/static/ruobing-it_favicon.png" mode="aspectFit" />
    </view>
    <text class="app-name">若冰代码手册</text>
    <text class="app-slogan">专业的代码分享平台</text>
  </view>

  <view class="login-card">
    <text class="card-title">欢迎回来</text>
    <text class="card-desc">登录后解锁更多精彩内容</text>
    <view class="wechat-panel">
      <button
        class="wx-login-btn {{loading ? 'wx-login-btn--busy' : ''}}"
        hover-class="wx-login-btn-hover"
        bindtap="onLoginTap"
      >
        <text class="btn-text">{{loading ? '登录中…' : '微信授权登录'}}</text>
      </button>
    </view>

    <view class="agreement-row">
      <view class="agreement-center">
        <view class="check-wrap" catchtap="toggleAgree">
          <view class="check-circle {{agreed ? 'checked' : ''}}">
            <text class="check-mark" wx:if="{{agreed}}">✓</text>
          </view>
        </view>
        <view class="agreement-text">
          <text class="agreement-plain">登录即表示同意</text>
          <text class="link" catchtap="openLegal" data-type="user">《用户协议》</text>
          <text class="agreement-plain">和</text>
          <text class="link" catchtap="openLegal" data-type="privacy">《隐私政策》</text>
        </view>
      </view>
    </view>
  </view>
</view>
