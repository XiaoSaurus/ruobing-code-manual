/* 意见反馈：随全局主题 --theme-color / --theme-light / --theme-dark */

.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, var(--theme-light, #f5f7fa) 0%, #f0f2f5 240rpx);
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx 44rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.form-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1c1c28;
  flex: 1;
  min-width: 0;
}

/* 次要入口：浅色块 + 小圆角，易点按且不抢主按钮 */
.record-chip {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 22rpx;
  border-radius: 14rpx;
  background: var(--theme-light, #e6f4ff);
  box-sizing: border-box;
}

.record-chip-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--theme-dark, #409eff);
}

.record-chip-arrow {
  font-size: 26rpx;
  line-height: 1;
  color: var(--theme-dark, #409eff);
  opacity: 0.55;
}

.record-chip-hover {
  opacity: 0.82;
}

.form-subtitle {
  font-size: 26rpx;
  color: #909399;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.field {
  margin-bottom: 36rpx;
}

.field-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.required {
  color: #f56c6c;
  margin-left: 4rpx;
}

.textarea {
  width: 100%;
  min-height: 240rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8eaed;
  border-radius: 14rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.8;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: #c0c4cc;
  margin-top: 10rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8eaed;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 主按钮：主题渐变 + 圆角胶囊，与登录页授权按钮气质一致 */
.submit-btn {
  width: 100%;
  margin-top: 28rpx;
  padding: 0;
  min-height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, var(--theme-dark, #409eff) 0%, var(--theme-color, #66b1ff) 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.12);
}

.submit-btn[disabled] {
  background: #dcdfe6 !important;
  color: #fff !important;
  box-shadow: none !important;
  opacity: 0.85;
}

.submit-btn::after {
  border: none;
}

.submit-btn-hover {
  opacity: 0.92;
}

.submit-btn[disabled].submit-btn-hover {
  opacity: 0.85;
}
