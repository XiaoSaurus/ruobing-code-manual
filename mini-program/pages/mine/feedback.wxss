/* 反馈页面 */
.container { padding: 30rpx; min-height: 100vh; background: #f5f5f5; }

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.form-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.field { margin-bottom: 36rpx; }

.field-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.required { color: #f56c6c; margin-left: 4rpx; }

.textarea {
  width: 100%;
  min-height: 240rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8eaed;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.8;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 10rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8eaed;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 20rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(64, 158, 255, 0.3);
}

.submit-btn[disabled] {
  background: #c0d4f0;
  box-shadow: none;
}

.submit-btn::after { border: none; }
