.container { padding: 20rpx; }
.form { background: #fff; border-radius: 16rpx; padding: 30rpx; }
.content-input { width: 100%; height: 300rpx; border: 1rpx solid #eee; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; margin-bottom: 20rpx; box-sizing: border-box; }
.contact-input { width: 100%; border: 1rpx solid #eee; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; margin-bottom: 30rpx; box-sizing: border-box; }
.submit-btn { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; border: none; border-radius: 50rpx; }
