<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索网页设计..."
      confirm-type="search" value="{{keyword}}"
      bindinput="onKeywordInput" bindconfirm="onSearch" />
  </view>

  <!-- 工具栏：排序 + 视图切换 -->
  <view class="toolbar">
    <view class="sort-tabs">
      <view class="tab {{sortBy === 'sort_order' ? 'active' : ''}}" bindtap="onSort" data-sort="sort_order"><text>默认</text></view>
      <view class="tab {{sortBy === 'views' ? 'active' : ''}}" bindtap="onSort" data-sort="views"><text>最热</text></view>
      <view class="tab {{sortBy === 'latest' ? 'active' : ''}}" bindtap="onSort" data-sort="latest"><text>最新</text></view>
    </view>
    <view class="view-toggle" bindtap="toggleView">
      <text class="toggle-icon">{{viewMode === 'single' ? '☰' : '▦'}}</text>
    </view>
  </view>

  <!-- 单列 / 双列列表：共用一个容器，通过 class 切换 -->
  <view class="card-list view-{{viewMode}}">
    <view
      class="card card-{{viewMode}}"
      wx:for="{{list}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <image class="cover" src="{{item.coverImage || '/static/default.png'}}" mode="aspectFill" />
      <view class="card-content">
        <text class="card-title">{{item.title}}</text>
        <view class="card-footer">
          <view class="meta-item"><text class="meta-icon">👁</text><text>{{item.views || 0}}</text></view>
          <view class="meta-item"><text class="meta-icon">❤️</text><text>{{item.likes || 0}}</text></view>
          <view class="meta-item" wx:if="{{viewMode === 'single'}}"><text class="meta-icon">⭐</text><text>{{item.favorites || 0}}</text></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部状态 -->
  <view class="bottom-status" wx:if="{{loading || !hasMore}}">
    <view class="loading-indicator" wx:if="{{loading}}">
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
      <text class="loading-text">正在加载...</text>
    </view>
    <text class="no-more-text" wx:elif="{{!hasMore && list.length > 0}}">— 没有更多了 —</text>
  </view>
</view>