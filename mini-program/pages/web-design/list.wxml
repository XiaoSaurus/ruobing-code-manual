<view class="container">
  <!-- 搜索筛选 -->
  <view class="filter-bar">
    <input class="search-input" placeholder="搜索网页设计..." confirm-type="search" value="{{keyword}}" bindconfirm="onSearch" />
    <view class="sort-tabs">
      <text class="tab {{sortBy === 'sort_order' ? 'active' : ''}}" bindtap="onSort" data-sort="sort_order">默认</text>
      <text class="tab {{sortBy === 'views' ? 'active' : ''}}" bindtap="onSort" data-sort="views">最热</text>
      <text class="tab {{sortBy === 'latest' ? 'active' : ''}}" bindtap="onSort" data-sort="latest">最新</text>
    </view>
  </view>

  <!-- 列表 -->
  <view class="list">
    <view class="card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="card-inner">
        <view class="info">
          <text class="title">{{item.title}}</text>
          <text class="desc">{{item.description}}</text>
          <view class="tags">
            <text class="tag" wx:for="{{item.tagsArray}}" wx:key="index">{{item}}</text>
          </view>
          <view class="meta">
            <view class="meta-item"><text class="meta-icon">👁</text><text>{{item.views || 0}}</text></view>
            <view class="meta-item"><text class="meta-icon">❤️</text><text>{{item.likes || 0}}</text></view>
            <view class="meta-item"><text class="meta-icon">⭐</text><text>{{item.favorites || 0}}</text></view>
          </view>
        </view>
        <image class="cover" src="{{item.coverImage || '/static/default.png'}}" mode="aspectFill" />
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text bindtap="loadMore">加载更多</text>
  </view>
  <view class="no-more" wx:else>
    <text>没有更多了</text>
  </view>
</view>
