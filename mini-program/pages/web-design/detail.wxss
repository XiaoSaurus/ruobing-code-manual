.container { padding: 20rpx; background: var(--theme-bg); }
.detail { background: var(--theme-card); border-radius: 20rpx; overflow: hidden; box-shadow: 0 10rpx 28rpx rgba(0,0,0,0.06); border: 1rpx solid #edf1f6; }
.cover { width: 100%; height: 400rpx; }
.content { padding: 28rpx; }
.title { font-size: 36rpx; font-weight: bold; color: var(--theme-text); display: block; margin-bottom: 20rpx; }
.meta { display: flex; flex-wrap: wrap; font-size: 24rpx; color: var(--theme-text-light); margin-bottom: 8rpx; gap: 18rpx; }
.meta-time { font-size: 24rpx; color: var(--theme-text-light); margin-bottom: 20rpx; }
.tags { display: flex; flex-wrap: wrap; margin-bottom: 20rpx; }
.tag { padding: 8rpx 20rpx; background: var(--theme-light); color: var(--theme-dark); border-radius: 10rpx; font-size: 24rpx; margin-right: 15rpx; margin-bottom: 10rpx; }

/* жЦЗзЂ†йҐДиІИеН°зЙЗ */
.article-card { background: var(--theme-card); border-radius: 20rpx; overflow: hidden; box-shadow: 0 10rpx 28rpx rgba(0,0,0,0.06); border: 1rpx solid #edf1f6; }
.card-cover { width: 100%; height: 360rpx; }
.card-body { padding: 28rpx; }
.card-title { font-size: 34rpx; font-weight: bold; color: var(--theme-text); display: block; margin-bottom: 16rpx; }
.card-meta-row { display: flex; flex-wrap: wrap; font-size: 24rpx; color: var(--theme-text-light); margin-bottom: 8rpx; gap: 18rpx; }
.card-time-row { font-size: 24rpx; color: var(--theme-text-light); margin-bottom: 24rpx; }
.read-btn { background: linear-gradient(135deg, var(--theme-color) 0%, var(--theme-dark) 100%); color: #fff; border: none; font-size: 28rpx; border-radius: 44rpx; padding: 20rpx 0; }
.summary-card { background: linear-gradient(180deg, #ffffff 0%, var(--theme-light) 100%); border-radius: 14rpx; padding: 18rpx 20rpx; margin-top: 16rpx; margin-bottom: 16rpx; border: 1rpx solid #edf1f6; }
.summary-text { font-size: 26rpx; color: var(--theme-text); line-height: 1.68; display: block; word-break: break-word; }

/* еЇХйГ®еЫЇеЃЪжУНдљЬж†?*/
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: var(--theme-card);
  padding: 14rpx 18rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 8rpx 0;
  line-height: 1.2;
}
.action-btn::after { border: none; }
.btn-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #f3f5f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #4b5565;
}
.btn-text { font-size: 20rpx; color: var(--theme-text-light); margin-top: 6rpx; }
.btn-hover { opacity: 0.6; }

/* зВєиµЮжњАжіїзКґжА?*/
.action-btn-liked .btn-text { color: var(--theme-dark); font-weight: 600; }
.action-btn-liked .btn-icon { background: var(--theme-light); color: var(--theme-dark); }
.action-btn-liked { background: var(--theme-light) !important; border-radius: 12rpx; }

/* е£∞жШОеН°зЙЗ */
.disclaimer {
  margin: 20rpx 0;
  margin-bottom: calc(120rpx + env(safe-area-inset-bottom));
  padding: 16rpx 20rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
  border: 1rpx solid #ebedf0;
  box-shadow: 0 3rpx 10rpx rgba(0,0,0,0.025);
  text-align: center;
}
.disclaimer-text {
  font-size: 20rpx;
  color: #8b93a1;
  line-height: 1.58;
}
