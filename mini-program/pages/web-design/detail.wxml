<view class="container {{themeClass}}" style="{{pageStyle}}">
  <!-- 有 articleUrl → 显示文章预览卡片 + 按钮 -->
  <view class="article-card" wx:if="{{articleUrl && detail}}" bindtap="handleDoubleTap">
    <image class="card-cover" src="{{detail.coverImage}}" mode="aspectFill" />
    <view class="card-body">
      <text class="card-title">{{detail.title}}</text>
      <view class="summary-card">
        <rich-text class="summary-md" type="html" nodes="{{summaryHtml}}"></rich-text>
      </view>
      <view class="card-meta-row">
        <text>👁 {{detail.views || 0}}</text>
        <text>❤️ {{detail.likes || 0}}</text>
        <text>⭐ {{detail.favorites || 0}}</text>
      </view>
      <view class="card-time-row" wx:if="{{formattedTime}}">
        <text>🕒 {{formattedTime}}</text>
      </view>
      <button class="read-btn" catchtap="openArticle">阅读全文</button>
    </view>
  </view>

  <!-- 无 articleUrl → 展示本地详情 -->
  <view class="detail" wx:elif="{{detail}}" bindtap="handleDoubleTap">
    <image class="cover" src="{{detail.coverImage || '/static/default.png'}}" mode="aspectFill" />
    <view class="content">
      <text class="title">{{detail.title}}</text>
      <view class="meta">
        <text>👁 {{detail.views || 0}}</text>
        <text>❤️ {{detail.likes || 0}}</text>
        <text>⭐ {{detail.favorites || 0}}</text>
        <text>🕒 {{formattedTime}}</text>
      </view>
      
      <view class="summary-card">
        <rich-text class="summary-md" type="html" nodes="{{summaryHtml}}"></rich-text>
      </view>
      <view class="tags" wx:if="{{detail.tags}}">
        <text class="tag" wx:for="{{detail.tags.split(',')}}" wx:key="index">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 底部固定操作栏 -->
  <view class="action-bar">
    <button class="action-btn {{liked ? 'action-btn-liked' : ''}}" hover-class="btn-hover" bindtap="handleLike">
      <text class="btn-icon">{{liked ? '❤️' : '🤍'}}</text>
      <text class="btn-text">点赞</text>
    </button>
    <button class="action-btn {{collected ? 'action-btn-liked' : ''}}" hover-class="btn-hover" bindtap="handleCollect">
      <text class="btn-icon">{{collected ? '⭐' : '☆'}}</text>
      <text class="btn-text">收藏</text>
    </button>
    <button class="action-btn" hover-class="btn-hover" open-type="share">
      <text class="btn-icon">📤</text>
      <text class="btn-text">分享</text>
    </button>
    <button class="action-btn" hover-class="btn-hover" bindtap="handleDownload">
      <text class="btn-icon">📥</text>
      <text class="btn-text">下载</text>
    </button>
  </view>

  <!-- 声明卡片 - 放最下面 -->
  <view class="disclaimer">
  <text class="disclaimer-text">
    声明：部分资料来源于网络，非小程序作者原创，仅供学习交流使用。
    如有侵权，请联系作者删除。
  </text>
</view>
</view>
