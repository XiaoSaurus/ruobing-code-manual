<view class="container">
  <!-- 有 articleUrl → 显示文章预览卡片 + 按钮 -->
  <view class="article-card" wx:if="{{articleUrl && detail}}">
    <image class="card-cover" src="{{detail.coverImage}}" mode="aspectFill" />
    <view class="card-body">
      <text class="card-title">{{detail.title}}</text>
      <text class="card-summary">{{detail.description}}</text>
      <view class="card-meta">
        <text>{{detail.views}} 浏览</text>
        <text>{{detail.likes}} 点赞</text>
      </view>
      <button class="read-btn" bindtap="openArticle">阅读全文</button>
    </view>
  </view>

  <!-- 无 articleUrl → 展示本地详情 -->
  <view class="detail" wx:elif="{{detail}}">
    <image class="cover" src="{{detail.coverImage || '/static/default.png'}}" mode="aspectFill" />
    <view class="content">
      <text class="title">{{detail.title}}</text>
      <view class="meta">
        <text>{{detail.views}} 浏览</text>
        <text>{{detail.likes}} 点赞</text>
        <text>{{detail.createTime}}</text>
      </view>
      <view class="tags">
        <text class="tag" wx:for="{{detail.tags.split(',')}}" wx:key="index">{{item}}</text>
      </view>
      <view class="desc">{{detail.description}}</view>
      <view class="code-section">
        <view class="section-title">代码内容</view>
        <view class="code-block">{{detail.content}}</view>
      </view>
    </view>
  </view>
</view>
