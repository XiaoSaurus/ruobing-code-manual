.container { padding: 20rpx; }
.filter-bar { background: #fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 20rpx; }
.search-input { background: #f5f5f5; border-radius: 50rpx; padding: 20rpx 30rpx; font-size: 28rpx; margin-bottom: 20rpx; }
.sort-tabs { display: flex; }
.tab { flex: 1; text-align: center; padding: 15rpx 0; color: #666; font-size: 28rpx; }
.tab.active { color: #409eff; border-bottom: 4rpx solid #409eff; }
.list {}
.card { background: #fff; border-radius: 16rpx; margin-bottom: 20rpx; overflow: hidden; }
.card-inner { display: flex; padding: 20rpx; }
.info { flex: 1; margin-right: 20rpx; }
.title { font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 10rpx; }
.desc { font-size: 26rpx; color: #666; display: block; margin-bottom: 15rpx; }
.tags { display: flex; flex-wrap: wrap; margin-bottom: 10rpx; }
.tag { padding: 4rpx 16rpx; background: #ecf5ff; color: #409eff; border-radius: 8rpx; font-size: 22rpx; margin-right: 10rpx; margin-bottom: 8rpx; }
.meta { display: flex; font-size: 24rpx; color: #999; }
.meta text { margin-right: 20rpx; }
.cover { width: 200rpx; height: 150rpx; border-radius: 12rpx; }
.load-more, .no-more { text-align: center; padding: 30rpx; color: #999; font-size: 26rpx; }
