/* 列表页通用 */
page { background: #f0f2f5; }
.container { padding: 24rpx; }

/* 搜索筛选栏 */
.filter-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.search-input {
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}
.sort-tabs {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  color: #999;
  font-size: 28rpx;
  position: relative;
}
.tab.active {
  color: #409eff;
  font-weight: bold;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #409eff;
  border-radius: 2rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.card-inner {
  display: flex;
  padding: 22rpx;
}
.info { flex: 1; margin-right: 20rpx; overflow: hidden; }
.title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tags { display: flex; flex-wrap: wrap; margin-bottom: 12rpx; gap: 10rpx; }
.tag {
  padding: 4rpx 14rpx;
  background: #ecf5ff;
  color: #409eff;
  border-radius: 8rpx;
  font-size: 22rpx;
}
/* 底部统计 */
.meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}
.meta-item { display: flex; align-items: center; margin-right: 20rpx; }
.meta-icon { margin-right: 6rpx; }

.cover {
  width: 200rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 26rpx;
}
