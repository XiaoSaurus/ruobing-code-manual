/* Apple-inspired Minimal Design */

page {
  background: #fafafa;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
}

.container {
  padding: 40rpx 48rpx 60rpx;
}

/* ========== 搜索栏 - Apple风格 ========== */
.search-section {
  margin-bottom: 32rpx;
}
.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
}
.search-icon {
  color: #86868b;
  font-size: 32rpx;
  margin-right: 16rpx;
}
.search-input {
  flex: 1;
  height: 48rpx;
  font-size: 30rpx;
  color: #1d1d1f;
  background: transparent;
}
.search-input::placeholder {
  color: #86868b;
}

/* ========== 排序栏 - Apple风格 ========== */
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}
.filter-item {
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  color: #86868b;
  transition: color 0.2s;
}
.filter-item.active {
  color: #1d1d1f;
  font-weight: 600;
}
.filter-divider {
  width: 1px;
  height: 24rpx;
  background: #d2d2d7;
  margin: 0 8rpx;
}

/* ========== 卡片 - Apple风格 ========== */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}
.card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.card:active {
  opacity: 0.95;
}
.cover {
  width: 100%;
  height: 360rpx;
  display: block;
}
.card-body {
  padding: 28rpx 32rpx;
}
.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  line-height: 1.4;
  display: block;
  margin-bottom: 16rpx;
}
.stats {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #86868b;
}
.stat {
  display: inline-block;
}

/* ========== 加载状态 ========== */
.load-status {
  text-align: center;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: #86868b;
}