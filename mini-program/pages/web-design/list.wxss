page { background: #f0f2f5; }
.container { padding: 24rpx; }

/* ========== 搜索栏（参考首页风格） ========== */
.search-bar {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.search-wrap {
  display: flex;
  align-items: center;
  background: #f5f6fa;
  border: 2rpx solid transparent;
  border-radius: 32rpx;
  padding: 0 12rpx 0 28rpx;
  transition: all 0.2s;
}
.search-wrap.focused {
  border-color: var(--theme-color, #409eff);
  background: #fff;
  box-shadow: 0 0 0 6rpx rgba(64,158,255,0.12);
}
.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
  background: transparent;
  border: none;
  outline: none;
}
.search-input::placeholder { color: #b0b0b0; }
.search-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--theme-color, #409eff);
  border-radius: 50%;
  flex-shrink: 0;
}
.search-btn .iconfont {
  font-size: 28rpx;
  filter: grayscale(100%) brightness(200%);
}

/* ========== 排序标签 ========== */
.sort-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}
.tab text { pointer-events: none; }
.tab.active {
  background: var(--theme-color, #409eff);
  color: #fff;
  font-weight: 600;
}

/* ========== 卡片（参考首页质感） ========== */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
}
.card-inner {
  display: flex;
  padding: 24rpx;
  align-items: center;
}
.info {
  flex: 1;
  margin-right: 20rpx;
  overflow: hidden;
}
.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.desc {
  font-size: 26rpx;
  color: #888;
  display: block;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}
.tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 14rpx;
  gap: 10rpx;
}
.tag {
  padding: 5rpx 14rpx;
  background: #ecf5ff;
  color: var(--theme-color, #409eff);
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
}
.meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #bbb;
}
.meta-item {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}
.meta-icon {
  margin-right: 5rpx;
  font-size: 22rpx;
}
.cover {
  width: 200rpx;
  height: 160rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
}

/* ========== 加载更多 ========== */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: var(--theme-color, #409eff);
  font-size: 26rpx;
}
.no-more {
  text-align: center;
  padding: 24rpx;
  color: #ccc;
  font-size: 24rpx;
}
