page { background: #f8f9fa; }
.container { padding: 24rpx 30rpx 40rpx; }

/* ========== 搜索栏 - Apple风格 ========== */
.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}
.search-icon {
  color: #86868b;
  font-size: 28rpx;
  margin-right: 12rpx;
}
.search-input {
  flex: 1;
  height: 48rpx;
  font-size: 28rpx;
  color: #1d1d1f;
  background: transparent;
}
.search-input::placeholder {
  color: #86868b;
}

/* ========== 排序标签 ========== */
.sort-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}
.tab text { pointer-events: none; }
.tab.active {
  background: var(--theme-color, #409eff);
  color: #fff;
  font-weight: 600;
}

/* ========== 卡片列表（参考首页） ========== */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  transition: all 0.3s ease;
}
.card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}
.cover {
  width: 100%;
  height: 320rpx;
  display: block;
}
.card-content {
  padding: 20rpx 24rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}
.card-footer {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}
.meta-item {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
}
.meta-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

/* ========== 加载更多 ========== */
.load-more {
  text-align: center;
  padding: 36rpx;
  color: var(--theme-color, #409eff);
  font-size: 26rpx;
}
.no-more {
  text-align: center;
  padding: 24rpx;
  color: #ccc;
  font-size: 24rpx;
}
