/* 首页样式 */
page { background: #f8f9fa; }

.container { padding-bottom: 40rpx; }

/* 搜索栏 - 简洁高级风格 */
.search-bar {
  padding: 24rpx 30rpx;
  background: #fff;
}
.search-inner {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}
.search-inner:focus-within {
  border-color: var(--theme-color);
  background: #fff;
  box-shadow: 0 0 0 4rpx var(--theme-light);
}
.search-icon-img {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 400;
}
.search-input::placeholder {
  color: #999;
}
.search-btn {
  background: var(--theme-color);
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  margin-left: 16rpx;
  transition: all 0.2s ease;
}
.search-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* Section 通用 - 简洁高级 */
.section { padding: 30rpx; }
.section-header {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-left: 12rpx;
  letter-spacing: 1rpx;
}
.section-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.9;
}

/* 搜索结果 */
.search-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}
.search-clear {
  font-size: 24rpx;
  color: var(--theme-color);
  margin-left: auto;
  margin-right: 8rpx;
}
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #bbb;
  font-size: 28rpx;
}

/* 卡片列表 - 简洁高级 */
.card-list { display: flex; flex-direction: column; gap: 20rpx; }

.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  transition: all 0.3s ease;
}
.card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}
.cover {
  width: 100%;
  height: 320rpx;
  display: block;
}
.card-content {
  padding: 20rpx 24rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

/* 底部统计栏 */
.card-footer {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}
.meta-item {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
}
.meta-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}
