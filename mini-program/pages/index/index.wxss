/* 首页样式 */
page { background: #f8f9fa; }

.container { padding-bottom: 40rpx; }

/* 搜索栏 - 简洁高级风格 */
.search-bar {
  padding: 24rpx 30rpx;
  background: #fff;
}
.search-inner {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 40rpx;
  padding: 14rpx 12rpx 14rpx 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}
.search-inner:focus-within {
  border-color: var(--theme-color);
  background: #fff;
  box-shadow: 0 0 0 4rpx var(--theme-light);
}
.search-icon-img {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.45;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 400;
}
.search-input::placeholder {
  color: #aaa;
}
.search-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--theme-color) 0%, var(--theme-dark, #5b5fc7) 100%);
  color: #fff;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  margin-left: 12rpx;
  box-shadow: 0 4rpx 16rpx var(--theme-shadow, rgba(102,102,204,0.3));
  transition: all 0.25s ease;
}
.search-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx var(--theme-shadow, rgba(102,102,204,0.2));
}
.search-btn-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  opacity: 0.9;
}
.search-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* Section 通用 - 简洁高级 */
.section { padding: 30rpx; }
.section-header {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-left: 12rpx;
  letter-spacing: 1rpx;
}
.section-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.9;
}

/* 搜索结果 */
.search-result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}
.search-result-left {
  display: flex;
  align-items: center;
}
.search-result-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}
.search-result-badge {
  background: var(--theme-color);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  min-width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 20rpx;
  padding: 0 14rpx;
  margin-left: 16rpx;
}
.search-clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e0e0e0;
  background: #fff;
  transition: all 0.2s ease;
}
.search-clear-btn:active {
  background: #f5f5f5;
  border-color: #ccc;
}
.search-clear-icon {
  font-size: 22rpx;
  color: #999;
  margin-right: 6rpx;
}
.search-clear-text {
  font-size: 24rpx;
  color: #777;
  font-weight: 500;
}
.empty-tip {
  text-align: center;
  padding: 100rpx 60rpx;
  color: #ccc;
  font-size: 28rpx;
  background: #fff;
  border-radius: 20rpx;
}

/* 卡片列表 - 简洁高级 */
.card-list { display: flex; flex-direction: column; gap: 20rpx; }

.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  transition: all 0.3s ease;
}
.card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}
.cover {
  width: 100%;
  height: 320rpx;
  display: block;
}
.card-content {
  padding: 20rpx 24rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

/* 底部统计栏 */
.card-footer {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}
.meta-item {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
}
.meta-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}
