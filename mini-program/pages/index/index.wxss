.search-bar {
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
.search-input {
  background: #fff;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}
.section {
  padding: 30rpx;
}
.section-header {
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.card-list {
  display: flex;
  flex-direction: column;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.cover {
  width: 100%;
  height: 300rpx;
}
.card-content {
  padding: 20rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}
.card-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}
.tag {
  padding: 4rpx 16rpx;
  background: #ecf5ff;
  color: #409eff;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}
.card-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}
