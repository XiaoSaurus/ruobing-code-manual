<view class="container">
  <!-- 轮播图 -->
  <view class="banner-wrap">
    <swiper class="banner-swiper" indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#fff" autoplay circular interval="4000" duration="600">
      <swiper-item>
        <image class="banner-img" src="/static/banners/banner-design.png" mode="aspectFill" />
      </swiper-item>
      <swiper-item>
        <image class="banner-img" src="/static/banners/banner-graduation.png" mode="aspectFill" />
      </swiper-item>
      <swiper-item>
        <image class="banner-img" src="/static/banners/banner-theme.png" mode="aspectFill" />
      </swiper-item>
      <swiper-item>
        <image class="banner-img" src="/static/banners/banner-update.png" mode="aspectFill" />
      </swiper-item>
    </swiper>
  </view>

  <!-- 热门推荐 -->
  <view class="section">
    <view class="section-header">
      <image class="section-icon" src="/static/section_icons/section-hot.png" mode="aspectFit" />
      <text class="section-title">热门推荐</text>
    </view>
    <view class="card-list">
      <view class="card" wx:for="{{hotList}}" wx:key="id" bindtap="goDetail" data-type="{{item._type}}" data-id="{{item.id}}">
        <image class="cover" src="{{item.coverImage || '/static/default.png'}}" mode="aspectFill" />
        <view class="card-content">
          <text class="card-title">{{item.title}}</text>
          <view class="card-footer">
            <view class="meta-item"><text class="meta-icon">👁</text><text>{{item.views || 0}}</text></view>
            <view class="meta-item"><text class="meta-icon">❤️</text><text>{{item.likes || 0}}</text></view>
            <view class="meta-item"><text class="meta-icon">⭐</text><text>{{item.favorites || 0}}</text></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 最新更新 -->
  <view class="section">
    <view class="section-header">
      <image class="section-icon" src="/static/section_icons/section-new.png" mode="aspectFit" />
      <text class="section-title">最新更新</text>
    </view>
    <view class="card-list">
      <view class="card" wx:for="{{latestList}}" wx:key="id" bindtap="goDetail" data-type="{{item._type}}" data-id="{{item.id}}">
        <image class="cover" src="{{item.coverImage || '/static/default.png'}}" mode="aspectFill" />
        <view class="card-content">
          <text class="card-title">{{item.title}}</text>
          <view class="card-footer">
            <view class="meta-item"><text class="meta-icon">👁</text><text>{{item.views || 0}}</text></view>
            <view class="meta-item"><text class="meta-icon">❤️</text><text>{{item.likes || 0}}</text></view>
            <view class="meta-item"><text class="meta-icon">⭐</text><text>{{item.favorites || 0}}</text></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>