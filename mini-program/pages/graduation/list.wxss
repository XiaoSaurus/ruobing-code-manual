page { background: #f8f9fa; }
.container { padding: 24rpx 30rpx 40rpx; }

/* ========== 搜索栏 - Apple风格 ========== */
.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}
.search-icon {
  color: #86868b;
  font-size: 28rpx;
  margin-right: 12rpx;
}
.search-input {
  flex: 1;
  height: 48rpx;
  font-size: 28rpx;
  color: #1d1d1f;
  background: transparent;
}
.search-input::placeholder {
  color: #86868b;
}

/* ========== 工具栏（排序 + 视图切换） ========== */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.sort-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
  flex: 1;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}
.tab text { pointer-events: none; }
.tab.active {
  background: var(--theme-color, #409eff);
  color: #fff;
  font-weight: 600;
}

/* ========== 卡片列表（参考首页） ========== */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  transition: all 0.3s ease;
}
.card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}
.cover {
  width: 100%;
  height: 320rpx;
  display: block;
}
.card-content { padding: 20rpx 24rpx; }
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}
.card-footer {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}
.meta-item {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
}
.meta-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

/* ========== 底部加载状态 ========== */
.bottom-status {
  padding: 40rpx 0;
  text-align: center;
}
.loading-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
}
.loading-dot {
  width: 8rpx;
  height: 8rpx;
  background: #86868b;
  border-radius: 50%;
  margin: 0 6rpx;
  animation: bounce 1.4s infinite ease-in-out both;
}
.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }
.loading-text {
  font-size: 24rpx;
  color: #86868b;
  margin-left: 12rpx;
}
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}
.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}

/* ========== 视图切换按钮 ========== */
.view-toggle {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 12rpx;
  margin-left: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.toggle-icon {
  font-size: 32rpx;
  color: #1d1d1f;
}

/* ========== 双列瀑布流 ========== */
.double {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.double .card {
  width: 48%;
  margin-bottom: 16rpx;
}
.double .cover {
  height: 200rpx;
}
.double .card-content {
  padding: 12rpx 16rpx;
}
.double .card-title {
  font-size: 26rpx;
  margin-bottom: 8rpx;
  line-height: 1.4;
}
.double .card-footer {
  font-size: 20rpx;
}
.double .meta-item {
  margin-right: 12rpx;
}
.double .meta-icon {
  font-size: 20rpx;
}
