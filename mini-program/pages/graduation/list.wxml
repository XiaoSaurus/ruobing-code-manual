<view class="container">
  <!-- 搜索栏 - Apple风格 -->
  <view class="search-section">
    <view class="search-bar">
      <text class="search-icon">􀊫</text>
      <input class="search-input" placeholder="搜索毕业设计..."
        confirm-type="search" value="{{keyword}}"
        bindinput="onKeywordInput" bindconfirm="onSearch" />
    </view>
  </view>

  <!-- 排序 - Apple风格 -->
  <view class="filter-bar">
    <view class="filter-item {{sortBy === 'sort_order' ? 'active' : ''}}" bindtap="onSort" data-sort="sort_order">
      <text>默认</text>
    </view>
    <view class="filter-divider"></view>
    <view class="filter-item {{sortBy === 'views' ? 'active' : ''}}" bindtap="onSort" data-sort="views">
      <text>最热</text>
    </view>
    <view class="filter-divider"></view>
    <view class="filter-item {{sortBy === 'latest' ? 'active' : ''}}" bindtap="onSort" data-sort="latest">
      <text>最新</text>
    </view>
  </view>

  <!-- 卡片列表 -->
  <view class="card-list">
    <view class="card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <image class="cover" src="{{item.coverImage || '/static/default.png'}}" mode="aspectFill" />
      <view class="card-body">
        <text class="title">{{item.title}}</text>
        <view class="stats">
          <text class="stat">{{item.views || 0}} 浏览</text>
          <text class="stat">{{item.likes || 0}} 喜欢</text>
          <text class="stat">{{item.favorites || 0}} 收藏</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="load-status">
    <text wx:if="{{hasMore}}" bindtap="loadMore">查看更多</text>
    <text wx:else>已显示全部内容</text>
  </view>
</view>