.container { padding: 20rpx; }
.detail { background: #fff; border-radius: 16rpx; overflow: hidden; }
.cover { width: 100%; height: 400rpx; }
.content { padding: 30rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #333; display: block; margin-bottom: 20rpx; }
.meta { display: flex; font-size: 24rpx; color: #999; margin-bottom: 20rpx; }
.meta text { margin-right: 20rpx; }
.tags { display: flex; flex-wrap: wrap; margin-bottom: 20rpx; }
.tag { padding: 8rpx 20rpx; background: #ecf5ff; color: #409eff; border-radius: 8rpx; font-size: 24rpx; margin-right: 15rpx; margin-bottom: 10rpx; }
.desc { font-size: 28rpx; color: #666; line-height: 1.8; margin-bottom: 30rpx; }
.code-section { margin-top: 30rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; }
.code-block { background: #f8f8f8; padding: 30rpx; border-radius: 12rpx; font-family: monospace; font-size: 26rpx; line-height: 1.8; white-space: pre-wrap; word-break: break-all; }

/* 文章预览卡片 */
.article-card { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08); }
.card-cover { width: 100%; height: 360rpx; }
.card-body { padding: 30rpx; }
.card-title { font-size: 34rpx; font-weight: bold; color: #333; display: block; margin-bottom: 16rpx; }
.card-summary { font-size: 28rpx; color: #666; line-height: 1.6; display: block; margin-bottom: 20rpx; }
.card-meta { display: flex; font-size: 24rpx; color: #999; margin-bottom: 24rpx; }
.card-meta text { margin-right: 20rpx; }
.read-btn { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; border: none; font-size: 28rpx; border-radius: 44rpx; padding: 20rpx 0; }

/* 底部固定操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 10rpx 0;
  line-height: 1.2;
}
.action-btn::after { border: none; }
.btn-icon { font-size: 40rpx; }
.btn-text { font-size: 22rpx; color: #666; margin-top: 4rpx; }
.btn-hover { opacity: 0.6; }

/* 声明卡片 */
.disclaimer {
  margin: 30rpx 0;
  margin-bottom: calc(120rpx + env(safe-area-inset-bottom));
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  text-align: center;
}
.disclaimer-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
