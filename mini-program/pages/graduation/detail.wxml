<view class="container" bindtouchstart="handleTouchStart" bindtouchend="handleTouchEnd">
  <!-- 有 articleUrl → 显示文章预览卡片 + 按钮 -->
  <view class="article-card" wx:if="{{articleUrl && detail}}">
    <image class="card-cover" src="{{detail.coverImage}}" mode="aspectFill" />
    <view class="card-body">
      <text class="card-title">{{detail.title}}</text>
      <text class="card-summary">{{detail.description}}</text>
      <view class="card-meta">
        <text>👁 {{detail.views}} 浏览</text>
        <text>❤️ {{detail.likes}} 点赞</text>
      </view>
      <button class="read-btn" bindtap="openArticle">阅读全文</button>
    </view>
  </view>

  <!-- 无 articleUrl → 展示本地详情 -->
  <view class="detail" wx:elif="{{detail}}">
    <image class="cover" src="{{detail.coverImage || '/static/default.png'}}" mode="aspectFill" />
    <view class="content">
      <text class="title">{{detail.title}}</text>
      <view class="meta"><text>👁 {{detail.views}} 浏览</text><text>❤️ {{detail.likes}} 点赞</text></view>
      <view class="tags"><text class="tag" wx:for="{{detail.tags.split(',')}}" wx:key="index">{{item}}</text></view>
      <view class="desc">{{detail.description}}</view>
      <view class="code-section">
        <view class="section-title">项目内容</view>
        <view class="code-block">{{detail.content}}</view>
      </view>
    </view>
  </view>

  <!-- 底部固定操作栏 -->
  <view class="action-bar">
    <button class="action-btn" hover-class="btn-hover" bindtap="handleLike">
      <text class="btn-icon">{{liked ? '❤️' : '🤍'}}</text>
      <text class="btn-text">{{liked ? '取消' : '点赞'}}</text>
    </button>
    <button class="action-btn" hover-class="btn-hover" open-type="share">
      <text class="btn-icon">📤</text>
      <text class="btn-text">分享</text>
    </button>
    <button class="action-btn" hover-class="btn-hover" bindtap="handleDownload">
      <text class="btn-icon">📥</text>
      <text class="btn-text">下载</text>
    </button>
  </view>

  <!-- 声明卡片 - 放最下面 -->
  <view class="disclaimer">
    <text class="disclaimer-text">声明：部分资料来源于络，非小程序作者原创，仅供学习交流使用，如有侵权，请联系作者删除。</text>
  </view>
</view>
