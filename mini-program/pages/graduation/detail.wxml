<view class="container">
  <!-- 有 articleUrl → 直接展示公众号文章 -->
  <web-view wx:if="{{articleUrl}}" src="{{articleUrl}}"></web-view>

  <!-- 无 articleUrl → 展示本地详情 -->
  <view class="detail" wx:elif="{{detail}}">
    <image class="cover" src="{{detail.coverImage || '/static/default.png'}}" mode="aspectFill" />
    <view class="content">
      <text class="title">{{detail.title}}</text>
      <view class="meta"><text>👁 {{detail.views}} 浏览</text><text>❤️ {{detail.likes}} 点赞</text></view>
      <view class="tags"><text class="tag" wx:for="{{detail.tags.split(',')}}" wx:key="index">{{item}}</text></view>
      <view class="desc">{{detail.description}}</view>
      <view class="code-section">
        <view class="section-title">项目内容</view>
        <view class="code-block">{{detail.content}}</view>
      </view>
    </view>
  </view>
</view>
