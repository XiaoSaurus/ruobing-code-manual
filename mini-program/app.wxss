/* 全局主题 CSS 变量 */
page {
  /* 默认「科技蓝」主题 */
  --theme-color: #66B1FF;
  --theme-light: #E6F4FF;
  --theme-dark: #409EFF;
  --theme-bg: #f5f5f5;
  --theme-card: #ffffff;
  --theme-text: #333333;
  --theme-text-light: #666666;
}

/* 主题类：page 或带 themeClass 的根节点 .container 均可 */
page.theme-blue,
.container.theme-blue {
  --theme-color: #66B1FF;
  --theme-light: #E6F4FF;
  --theme-dark: #409EFF;
}

page.theme-purple,
.container.theme-purple {
  --theme-color: #B388FF;
  --theme-light: #F3E8FF;
  --theme-dark: #9C27B0;
}

page.theme-green,
.container.theme-green {
  --theme-color: #85CE61;
  --theme-light: #E8F5E8;
  --theme-dark: #67C23A;
}

page.theme-orange,
.container.theme-orange {
  --theme-color: #F0C78A;
  --theme-light: #FFF7E6;
  --theme-dark: #E6A23C;
}

page.theme-red,
.container.theme-red {
  --theme-color: #F78989;
  --theme-light: #FFE8E8;
  --theme-dark: #F56C6C;
}

page.theme-pink,
.container.theme-pink {
  --theme-color: #F4B8C5;
  --theme-light: #FFEEF0;
  --theme-dark: #E88A9C;
}

page.theme-cyan,
.container.theme-cyan {
  --theme-color: #36CFC9;
  --theme-light: #E6FFFB;
  --theme-dark: #13C2C2;
}

page.theme-teal,
.container.theme-teal {
  --theme-color: #3EB489;
  --theme-light: #E8FFF4;
  --theme-dark: #08979C;
}

page.theme-indigo,
.container.theme-indigo {
  --theme-color: #7B95F6;
  --theme-light: #EEF2FF;
  --theme-dark: #5C6BC0;
}

page.theme-amber,
.container.theme-amber {
  --theme-color: #F5A623;
  --theme-light: #FFF8E6;
  --theme-dark: #D48806;
}

page.theme-rose,
.container.theme-rose {
  --theme-color: #F472B6;
  --theme-light: #FCE7F3;
  --theme-dark: #DB2777;
}

page.theme-lilac,
.container.theme-lilac {
  --theme-color: #B37FEB;
  --theme-light: #F9F0FF;
  --theme-dark: #9254DE;
}

/* 全局样式 */
page {
  background-color: var(--theme-bg);
  font-size: 28rpx;
  color: var(--theme-text);
}

.container { padding: 20rpx; }

.card {
  background: var(--theme-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--theme-text);
  margin-bottom: 16rpx;
}

.desc {
  font-size: 26rpx;
  color: var(--theme-text-light);
  line-height: 1.6;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: var(--theme-light);
  color: var(--theme-color);
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--theme-color) 0%, var(--theme-dark) 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* 通用 section 样式 */
.section { margin-bottom: 30rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0 10rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: var(--theme-text); }

/* 主题相关组件 */
.theme-bg { background-color: var(--theme-bg); }
.theme-card { background-color: var(--theme-card); }
.theme-text { color: var(--theme-text); }
.theme-text-light { color: var(--theme-text-light); }

/* 主题色边框 */
.theme-border {
  border: 2rpx solid var(--theme-color);
}

/* 主题色文字 */
.text-theme { color: var(--theme-color); }
/* 主题浅色背景 */
.bg-theme-light { background-color: var(--theme-light); }
/* 主题主色背景 */
.bg-theme { background-color: var(--theme-color); }
