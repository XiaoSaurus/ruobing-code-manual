/* 全局主题 CSS 变量 */
page {
  /* 默认科技蓝主题 */
  --theme-color: #409EFF;
  --theme-light: #ecf5ff;
  --theme-dark: #337ecc;
}

page.theme-blue {
  --theme-color: #409EFF;
  --theme-light: #ecf5ff;
  --theme-dark: #337ecc;
}

page.theme-purple {
  --theme-color: #9c27b0;
  --theme-light: #f3e5f5;
  --theme-dark: #7b1fa2;
}

page.theme-green {
  --theme-color: #67C23A;
  --theme-light: #f0f9eb;
  --theme-dark: #529b2e;
}

page.theme-orange {
  --theme-color: #E6A23C;
  --theme-light: #fdf6ec;
  --theme-dark: #c88c2e;
}

page.theme-red {
  --theme-color: #F56C6C;
  --theme-light: #fef0f0;
  --theme-dark: #d94f4f;
}

page.theme-dark {
  --theme-color: #409EFF;
  --theme-light: #1e2a3a;
  --theme-dark: #66b1ff;
}

page {
  background-color: #f5f5f5;
  font-size: 28rpx;
}

.container { padding: 20rpx; }

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: var(--theme-light);
  color: var(--theme-color);
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--theme-color) 0%, var(--theme-dark) 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* 通用 section 样式 */
.section { margin-bottom: 30rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0 10rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: #333; }
